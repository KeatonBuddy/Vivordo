rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User document + ALL subcollections ───────────────────────────────────
    // Subcollections covered: metrics_daily, preferences, questionaire_responses
    // Only the owning user may read or write their own data.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Panda session insights ────────────────────────────────────────────────
    // Written by the client; also written back to by Cloud Functions (batch).
    // Only the owning user may read their own insights.
    match /insights/{insightId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }

    // ── AI batch tracking (written by Cloud Functions only) ──────────────────
    match /batch_jobs/{batchId} {
      allow read: if request.auth != null;
    }

    // ── Weekly trends (written by pandaBatchNightly, read by the app) ─────────
    match /weekly_trends/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // ── Insight summaries (written by pandaBatchNightly, read by the app) ────
    match /insight_summaries/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
